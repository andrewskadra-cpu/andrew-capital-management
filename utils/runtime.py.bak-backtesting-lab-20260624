            if submitted:
                if not liability.strip():
                    st.error("Liability account name is required.")
                else:
                    updated = liabilities.copy()
                    match = updated["Account"].str.lower() == liability.strip().lower()
                    if match.any():
                        updated.loc[match, "Account"] = liability.strip()
                        updated.loc[match, "Type"] = liability_type
                        updated.loc[match, "Balance"] = balance
                    else:
                        updated = pd.concat(
                            [
                                updated,
                                pd.DataFrame([{"Account": liability.strip(), "Type": liability_type, "Balance": balance}]),
                            ],
                            ignore_index=True,
                        )
                    save_liabilities(updated)
                    st.success("Liability account saved.")
                    st.rerun()

