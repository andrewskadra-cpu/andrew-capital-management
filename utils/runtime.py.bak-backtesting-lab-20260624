def net_worth_snapshot_stats(snapshots: pd.DataFrame) -> dict[str, float]:
    if snapshots.empty:
        return {
            "highest": 0.0,
            "lowest": 0.0,
            "monthly_change": 0.0,
            "annualized_growth": 0.0,
        }

    ordered = snapshots.sort_values("Date").copy()
    highest = ordered["Net Worth"].max()
    lowest = ordered["Net Worth"].min()
    monthly_change = 0.0
    if len(ordered) >= 2:
        monthly_change = ordered["Net Worth"].iloc[-1] - ordered["Net Worth"].iloc[-2]

    annualized_growth = 0.0
    first_value = ordered["Net Worth"].iloc[0]
    last_value = ordered["Net Worth"].iloc[-1]
    first_date = pd.Timestamp(ordered["Date"].iloc[0])
    last_date = pd.Timestamp(ordered["Date"].iloc[-1])
    elapsed_years = max((last_date - first_date).days / 365.25, 0)
    if first_value > 0 and last_value > 0 and elapsed_years > 0:
        annualized_growth = ((last_value / first_value) ** (1 / elapsed_years) - 1) * 100

    return {
        "highest": highest,
        "lowest": lowest,
        "monthly_change": monthly_change,
        "annualized_growth": annualized_growth,
    }


def blended_growth_rate(
    expected_market_return: float,
    trading_return: float,
    real_estate_appreciation: float,
    acquisition_growth: float,
) -> float:
    return (
        expected_market_return * 0.40
        + trading_return * 0.20
        + real_estate_appreciation * 0.20
        + acquisition_growth * 0.20
    ) / 100


def build_net_worth_forecast(
    current_net_worth: float,
    annual_contributions: float,
    expected_market_return: float,
    trading_return: float,
    real_estate_appreciation: float,
    acquisition_growth: float,
) -> tuple[pd.DataFrame, float]:
    blended_rate = blended_growth_rate(
        expected_market_return,
        trading_return,
        real_estate_appreciation,
        acquisition_growth,
    )
    forecast_years = [1, 3, 5, 10, 20]
    rows = []
    for year in forecast_years:
        projected_value = current_net_worth
        for _ in range(year):
            projected_value = projected_value * (1 + blended_rate) + annual_contributions
        rows.append(
            {
                "Year": year,
                "Projected Net Worth": projected_value,
                "Contributions": annual_contributions * year,
                "Investment Growth": projected_value - current_net_worth - annual_contributions * year,
            }
        )
    return pd.DataFrame(rows), blended_rate


def years_to_target(current_net_worth: float, annual_contributions: float, annual_growth_rate: float, target: float) -> int | None:
    if current_net_worth >= target:
        return 0
    if annual_contributions <= 0 and annual_growth_rate <= 0:
        return None

    value = current_net_worth
    for year in range(1, 101):
        value = value * (1 + annual_growth_rate) + annual_contributions
        if value >= target:
            return year
    return None


def run_monte_carlo_net_worth(
    current_net_worth: float,
    annual_contributions: float,
    annual_growth_rate: float,
    simulation_count: int,
    years: int = 20,
) -> pd.DataFrame:
    import random

    volatility = max(abs(annual_growth_rate) * 0.75, 0.06)
    rows = []
    for simulation in range(simulation_count):
        value = current_net_worth
        for year in range(1, years + 1):
            simulated_return = random.gauss(annual_growth_rate, volatility)
            simulated_return = max(min(simulated_return, 0.45), -0.35)
            value = max(value * (1 + simulated_return) + annual_contributions, 0)
            rows.append({"Simulation": simulation + 1, "Year": year, "Net Worth": value})
    return pd.DataFrame(rows)


def monte_carlo_summary(results: pd.DataFrame) -> dict[str, float]:
    if results.empty:
        return {"best": 0.0, "expected": 0.0, "worst": 0.0}

    final_values = results.sort_values("Year").groupby("Simulation")["Net Worth"].last()
    return {
        "best": final_values.quantile(0.90),
        "expected": final_values.median(),
        "worst": final_values.quantile(0.10),
    }


def report_period_start(report_type: str) -> pd.Timestamp:
    today = pd.Timestamp.today().normalize()
    if report_type == "Weekly Report":
        return today - pd.Timedelta(days=7)
    if report_type == "Monthly Report":
        return today.replace(day=1)
    if report_type == "Quarterly Report":
        quarter_start_month = ((today.month - 1) // 3) * 3 + 1
        return today.replace(month=quarter_start_month, day=1)
    return today.replace(month=1, day=1)


def generate_executive_report(report_type: str) -> tuple[pd.DataFrame, dict[str, object]]:
    period_start = report_period_start(report_type)
    period_end = pd.Timestamp.today().normalize()

    trades = read_trades()
    trades["Date"] = pd.to_datetime(trades["Date"], errors="coerce")
    period_trades = trades[trades["Date"] >= period_start] if not trades.empty else trades

    assets = read_wealth_accounts()
    liabilities = read_liabilities()
    snapshots = read_net_worth_snapshots()
    properties = enrich_real_estate_properties(read_real_estate_properties())
    deals = read_acquisition_deals()

