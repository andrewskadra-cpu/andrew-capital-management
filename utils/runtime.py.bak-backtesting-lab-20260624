def render_trading_monte_carlo(trades: pd.DataFrame) -> None:
    st.subheader("Monte Carlo Simulation")
    if trades.empty:
        st.info("Add trades to run Monte Carlo simulations.")
        return

    col1, col2 = st.columns(2)
    starting_equity = col1.number_input("Starting Equity", min_value=0.0, value=35000.0, step=500.0, key="trading_monte_carlo_equity")
    trade_count = col2.number_input(
        "Projected Trade Count",
        min_value=1,
        value=max(len(trades), 30),
        step=1,
        key="trading_monte_carlo_trade_count",
    )
    bands, summary = run_trading_monte_carlo(trades, starting_equity, simulations=1000, trade_count=int(trade_count))
    if bands.empty or summary.empty:
        st.info("Monte Carlo needs at least one historical profit/loss value.")
        return

    expected_low = float(summary["Final Equity"].quantile(0.10))
    expected_mid = float(summary["Final Equity"].quantile(0.50))
    expected_high = float(summary["Final Equity"].quantile(0.90))
    worst_drawdown = float(summary["Worst Drawdown"].min())
    probability_profit = float((summary["Final Equity"] > starting_equity).mean() * 100)

    metric_col1, metric_col2, metric_col3 = st.columns(3)
    metric_col1.metric("Expected Equity Range", f"{money(expected_low)} - {money(expected_high)}")
    metric_col2.metric("Median Equity", money(expected_mid))
    metric_col3.metric("Worst Drawdown", money(worst_drawdown))
    st.caption(f"Probability of finishing above starting equity: {percent(probability_profit)}")

    if px is not None:
        fig = px.line(
            bands,
            x="Trade",
            y=["Worst Case", "Expected Case", "Best Case"],
            template="plotly_dark",
            title="Monte Carlo Probability Bands",
        )
        st.plotly_chart(fig, use_container_width=True)
    else:
        st.line_chart(bands.set_index("Trade")[["Worst Case", "Expected Case", "Best Case"]])


