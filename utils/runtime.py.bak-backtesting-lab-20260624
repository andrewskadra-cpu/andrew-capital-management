def money(value: float) -> str:
    return f"${value:,.2f}"


def percent(value: float) -> str:
    return f"{value:.1f}%"


def clamp_progress(value: float, target: float) -> float:
    if target <= 0:
        return 0.0
    return max(0.0, min(value / target, 1.0))


def render_kpi_card(label: str, value: str, note: str = "") -> None:
    st.markdown(
        f"""
        <div class="kpi-card">
            <div class="kpi-label">{label}</div>
            <div class="kpi-value">{value}</div>
            <div class="kpi-note">{note}</div>
        </div>
        """,
        unsafe_allow_html=True,
    )


def render_goal_progress(title: str, current: float, target: float, detail: str) -> None:
    progress = clamp_progress(current, target)
    st.markdown(
        f"""
        <div class="goal-card">
            <div class="goal-title">{title}</div>
            <div class="goal-meta">{detail}</div>
        </div>
        """,
        unsafe_allow_html=True,
    )
    st.progress(progress, text=f"{percent(progress * 100)} complete")


def safe_filename(value: str) -> str:
    cleaned = re.sub(r"[^A-Za-z0-9_.-]+", "_", value.strip())
    return cleaned.strip("._") or "image"


