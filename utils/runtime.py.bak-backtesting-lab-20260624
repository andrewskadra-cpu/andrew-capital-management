    entry_price = col3.number_input("Entry Price", min_value=0.0, value=100.0, step=0.01, key="risk_entry_price")
    stop_price = col4.number_input("Stop Price", min_value=0.0, value=95.0, step=0.01, key="risk_stop_price")
    target_price = col5.number_input("Target Price", min_value=0.0, value=110.0, step=0.01, key="risk_target_price")

    dollar_risk = account_size * risk_pct / 100
    risk_per_share = abs(entry_price - stop_price)
    recommended_shares = int(dollar_risk // risk_per_share) if risk_per_share else 0
    max_position_size = recommended_shares * entry_price
    reward_per_share = abs(target_price - entry_price)
    rr_ratio = reward_per_share / risk_per_share if risk_per_share else 0.0

    metric1, metric2, metric3, metric4, metric5 = st.columns(5)
    metric1.metric("Dollar Risk", money(dollar_risk))
    metric2.metric("Risk Per Share", money(risk_per_share))
    metric3.metric("Recommended Shares", f"{recommended_shares:,}")
    metric4.metric("Maximum Position Size", money(max_position_size))
    metric5.metric("Planned RR", f"{rr_ratio:.2f}")

    if risk_pct > 2:
        st.warning("Risk exceeds a conservative 2% account-risk limit.")
    if rr_ratio < 2:
        st.warning("Planned RR is below 2.0. Consider passing unless your edge justifies it.")
    if max_position_size > account_size:
        st.warning("Maximum position size exceeds account size.")


