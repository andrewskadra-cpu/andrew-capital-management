    trading_score = round(
        min(
            100.0,
            (35 if trading_summary["total_profit"] > 0 else 10)
            + min(max(trading_summary["win_rate"], 0), 100) * 0.25
            + min(max(trading_summary["avg_rr"], 0), 4) * 7
            + (15 if trading_metrics["profit_factor"] >= 1.5 else 5 if trading_metrics["profit_factor"] > 0 else 0),
        ),
        1,
    )
    real_estate_score = round(
        min(
            100.0,
            (25 if len(properties) else 0)
            + clamp_progress(real_estate_equity, 250_000.0) * 30
            + (20 if real_estate_cash_flow > 0 else 0)
            + min(max(real_estate_dscr, 0), 2.0) * 12.5,
        ),
        1,
    )
    acquisition_score = round(
        min(
            100.0,
            (20 if len(deals) else 0)
            + clamp_progress(acquisition_metrics["total_pipeline_value"], 1_000_000.0) * 25
            + clamp_progress(float(qualified_deals), 5.0) * 30
            + clamp_progress(float(closed_deals), 1.0) * 25,
        ),
        1,
    )
    execution_score = round(
        min(
            100.0,
            (20 if len(trades) else 0)
            + (20 if len(properties) else 0)
            + (20 if len(deals) else 0)
            + (20 if len(assets) else 0)
            + min(len(opportunities), 10) * 2,
        ),
        1,
    )
    goal_score = round(float(goals["Progress"].mean()) if not goals.empty else 0.0, 1)
    score_rows = pd.DataFrame(
        [
            {"Category": "Wealth", "Score": wealth_score},
            {"Category": "Trading", "Score": trading_score},
            {"Category": "Real Estate", "Score": real_estate_score},
            {"Category": "Acquisitions", "Score": acquisition_score},
            {"Category": "Execution", "Score": execution_score},
            {"Category": "Goal Progress", "Score": goal_score},
        ]
    )
    executive_score = round(float(score_rows["Score"].mean()), 1) if not score_rows.empty else 0.0

    strengths: list[str] = []
    weaknesses: list[str] = []
    risks: list[str] = []
    opportunity_notes: list[str] = []

    if net_worth > 0:
        strengths.append(f"Net worth is positive at {money(net_worth)}, with {money(total_assets)} in tracked assets.")
    else:
        weaknesses.append("Net worth is not yet positive based on tracked assets and liabilities.")
    if total_liabilities > total_assets * 0.5 and total_assets > 0:
        risks.append("Liabilities are elevated versus tracked assets; keep leverage under review.")
    if snapshots.empty:
        weaknesses.append("Monthly net worth snapshots are missing, limiting trend visibility.")

    if trading_summary["total_profit"] > 0:
        strengths.append(f"Trading has generated {money(trading_summary['total_profit'])} across {trading_summary['total_trades']:,} trades.")
    elif trading_summary["total_trades"] > 0:
        risks.append("Trading P&L is flat or negative; reduce size until setup quality improves.")
    else:
        opportunity_notes.append("Trading data is light; more logged trades will improve CIO confidence.")
    if trading_summary["win_rate"] < 50 and trading_summary["total_trades"] > 0:
        weaknesses.append("Trading win rate is below 50%; prioritize A/A+ setups and mistake reduction.")

    if real_estate_cash_flow > 0:
        strengths.append(f"Real estate produces {money(real_estate_cash_flow)} in annual cash flow.")
    elif len(properties):
        risks.append("Real estate cash flow is not positive; review rents, expenses, debt terms, and reserves.")
    else:
        opportunity_notes.append("No real estate properties are tracked; evaluate the first rental when capital permits.")
    if real_estate_dscr and real_estate_dscr < 1.25:
        risks.append("Real estate DSCR is below a conservative 1.25x threshold.")

    if acquisition_metrics["total_pipeline_value"] > 0:
        opportunity_notes.append(f"Acquisition pipeline value is {money(acquisition_metrics['total_pipeline_value'])}.")
    else:
        weaknesses.append("Acquisition pipeline has no tracked value yet.")
    if qualified_deals == 0:
        risks.append("No acquisition targets are currently qualified beyond early-stage review.")

    top_goal = goals.sort_values("Progress", ascending=False).iloc[0] if not goals.empty else None
    lowest_goal = goals.sort_values("Progress", ascending=True).iloc[0] if not goals.empty else None
    if top_goal is not None:
        strengths.append(f"Best goal progress: {top_goal['Goal']} at {percent(float(top_goal['Progress']))}.")
    if lowest_goal is not None and float(lowest_goal["Progress"]) < 25:
        weaknesses.append(f"Lowest goal progress: {lowest_goal['Goal']} at {percent(float(lowest_goal['Progress']))}.")

    if not opportunities.empty:
        best_opportunity = opportunities.iloc[0]
        capital_recommendation = (
            f"Additional capital should currently be allocated toward {best_opportunity['Opportunity']} "
            f"({best_opportunity['Opportunity Type']}) due to its {best_opportunity['Score']:.1f}/100 score, "
            f"{percent(float(best_opportunity['Expected ROI']))} expected ROI, and {best_opportunity['Risk Level'].lower()} risk profile."
        )
    else:
        best_opportunity = None
        capital_recommendation = "Additional capital should remain in cash until more opportunities are entered and scored."

    top_actions = []
    if trading_summary["total_trades"] > 0:
        top_actions.append("Review the last 10 trades and isolate the highest expectancy setup.")
    else:
        top_actions.append("Log every trade in the Trading Center so CIO analytics have a reliable data set.")
    if snapshots.empty:
        top_actions.append("Save this month’s net worth snapshot in the Wealth Dashboard.")
    if len(properties) == 0:
        top_actions.append("Underwrite one rental property candidate using the Real Estate module.")
    elif real_estate_dscr < 1.25 and real_estate_dscr > 0:
        top_actions.append("Improve real estate DSCR through refinance, rent review, or expense reduction.")
    if qualified_deals == 0:
        top_actions.append("Advance at least one acquisition target to NDA/CIM review.")
    if best_opportunity is not None:
        top_actions.append(f"Allocate new capital toward the highest-ranked opportunity: {best_opportunity['Opportunity']}.")
    for fallback_action in [
        "Update all portfolio data weekly so executive scoring stays current.",
        "Set one measurable capital allocation decision for the next operating review.",
        "Review the weakest CIO score category and assign one corrective action.",
    ]:
        if len(top_actions) >= 5:
            break
        top_actions.append(fallback_action)
    top_actions = top_actions[:5]

    next_90_days = [
        "Days 1-30: Clean data, update all accounts, save a net worth snapshot, and review trading mistakes.",
        "Days 31-60: Focus capital only on opportunities scoring above 65/100 and improve the weakest score category.",
        "Days 61-90: Execute one high-conviction action: advance an acquisition, refinance/analyze property debt, or scale only A+ trading setups.",
    ]

    briefing_sections = {
        "Net Worth Analysis": [
            f"Tracked assets: {money(total_assets)}.",
            f"Tracked liabilities: {money(total_liabilities)}.",
            f"Current net worth: {money(net_worth)}.",
        ],
        "Trading Analysis": [
            f"Total trading P&L: {money(trading_summary['total_profit'])}.",
            f"Win rate: {percent(trading_summary['win_rate'])}; average RR: {trading_summary['avg_rr']:.2f}.",
            f"Profit factor: {trading_metrics['profit_factor']:.2f}; expectancy: {money(trading_metrics['expectancy'])}.",
        ],
        "Real Estate Analysis": [
            f"Properties tracked: {len(properties):,}.",
            f"Equity: {money(real_estate_equity)}; annual cash flow: {money(real_estate_cash_flow)}.",
            f"NOI: {money(real_estate_noi)}; portfolio DSCR: {real_estate_dscr:.2f}x.",
        ],
        "Acquisition Analysis": [
            f"Deals reviewed: {len(deals):,}.",
            f"Pipeline value: {money(acquisition_metrics['total_pipeline_value'])}.",
            f"Qualified deals: {qualified_deals:,}; average multiple: {acquisition_metrics['average_multiple']:.2f}x.",
        ],
        "Goal Analysis": [
            f"Average goal progress: {percent(goal_score)}.",
            f"Highest progress: {top_goal['Goal'] if top_goal is not None else 'N/A'}.",
            f"Primary gap: {lowest_goal['Goal'] if lowest_goal is not None else 'N/A'}.",
        ],
    }

    return {
        "executive_score": executive_score,
        "score_rows": score_rows,
        "briefing_sections": briefing_sections,
        "strengths": strengths[:6] or ["No major strengths detected yet; add more operating data to the system."],
        "weaknesses": weaknesses[:6] or ["No major weaknesses detected from the current data."],
        "risks": risks[:6] or ["No critical risks detected from the current data."],
        "opportunities": opportunity_notes[:6] or ["Add more opportunities to improve capital allocation precision."],
        "capital_recommendation": capital_recommendation,
        "top_actions": top_actions,
        "next_90_days": next_90_days,
        "goals": goals,
        "opportunity_leaderboard": opportunities,
        "kpis": {
            "Net Worth": net_worth,
            "Trading P&L": trading_summary["total_profit"],
            "Real Estate Equity": real_estate_equity,
            "Pipeline Value": acquisition_metrics["total_pipeline_value"],
        },
    }


