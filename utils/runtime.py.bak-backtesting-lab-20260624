def acquisition_pipeline_metrics(deals: pd.DataFrame) -> dict[str, float]:
    qualified_statuses = ["NDA", "CIM", "LOI", "Due Diligence", "Closed"]
    deals_reviewed = len(deals)
    deals_qualified = int(deals["Status"].isin(qualified_statuses).sum()) if not deals.empty else 0
    average_multiple = deals["Multiple"].mean() if not deals.empty else 0.0
    total_pipeline_value = deals["Asking Price"].sum() if not deals.empty else 0.0
    average_deal_size = deals["Asking Price"].mean() if not deals.empty else 0.0
    return {
        "deals_reviewed": deals_reviewed,
        "deals_qualified": deals_qualified,
        "average_multiple": average_multiple,
        "total_pipeline_value": total_pipeline_value,
        "average_deal_size": average_deal_size,
    }


def parse_optional_date(value: object) -> date | None:
    parsed = pd.to_datetime(value, errors="coerce")
    if pd.isna(parsed):
        return None
    return parsed.date()


def calculate_acquisition_score(row: pd.Series) -> float:
    asking_price = float(row.get("Asking Price", 0.0))
    ebitda = float(row.get("EBITDA", 0.0))
    revenue = float(row.get("Revenue", 0.0))
    multiple = float(row.get("Multiple", 0.0))
    expected_return = (ebitda / asking_price * 100) if asking_price else 0.0
    revenue_quality = (ebitda / revenue * 100) if revenue else 0.0
    status_score = DEAL_STATUSES.index(str(row.get("Status", "Lead"))) / (len(DEAL_STATUSES) - 1) * 100
    multiple_score = bounded_score(multiple, 6.0, 2.0) if multiple else 40.0
    return_score = bounded_score(expected_return, 0.0, 35.0)
    margin_score = bounded_score(revenue_quality, 0.0, 30.0)
    contact_score = 0.0
    for column in ["Broker Name", "Contact Information", "Website"]:
        if str(row.get(column, "")).strip():
            contact_score += 33.3
    follow_up = parse_optional_date(row.get("Follow-Up Date", ""))
    follow_up_score = 75.0
    if follow_up and follow_up < date.today() and str(row.get("Status", "")) != "Closed":
        follow_up_score = 35.0

    score = (
        return_score * 0.30
        + multiple_score * 0.20
        + margin_score * 0.15
        + status_score * 0.15
        + contact_score * 0.10
        + follow_up_score * 0.10
    )
    return round(max(0.0, min(score, 100.0)), 1)


def acquisition_recommendation(score: float, status: str) -> str:
    if status == "Closed":
        return "Closed - monitor post-close performance."
    if score >= 80:
        return "Prioritize diligence and financing."
    if score >= 65:
        return "Strong candidate - advance to next stage."
    if score >= 50:
        return "Keep active, but validate economics."
    return "Low priority unless price or terms improve."


def enrich_acquisition_deals(deals: pd.DataFrame) -> pd.DataFrame:
    enriched = deals.copy()
    if enriched.empty:
        enriched["Acquisition Score"] = []
        enriched["Recommendation"] = []
        return enriched

    enriched["Acquisition Score"] = enriched.apply(calculate_acquisition_score, axis=1)
    enriched["Recommendation"] = enriched.apply(
        lambda row: acquisition_recommendation(float(row["Acquisition Score"]), str(row["Status"])),
        axis=1,
    )
    return enriched


def acquisition_conversion_rates(deals: pd.DataFrame) -> pd.DataFrame:
    counts = deals["Status"].value_counts().reindex(DEAL_STATUSES, fill_value=0) if not deals.empty else pd.Series(0, index=DEAL_STATUSES)
    rows = []
    prior_count = None
    for status in DEAL_STATUSES:
        count = int(counts.loc[status])
        conversion = 100.0 if prior_count is None else (count / prior_count * 100 if prior_count else 0.0)
        rows.append({"Stage": status, "Deals": count, "Conversion Rate": conversion})
        prior_count = count
    return pd.DataFrame(rows)


def calculate_profit(direction: str, entry: float, exit_price: float, shares: float) -> float:
    if direction == "Short":
        return (entry - exit_price) * shares
    return (exit_price - entry) * shares


def calculate_rr(entry: float, stop: float, target: float) -> float:
    risk = abs(entry - stop)
    reward = abs(target - entry)
    return reward / risk if risk > 0 else 0.0


def filter_trade_history(trades: pd.DataFrame, key_prefix: str) -> pd.DataFrame:
    if trades.empty:
        st.info("No trades entered yet.")
        return trades

    ticker_options = sorted(ticker for ticker in trades["Ticker"].dropna().unique() if ticker)
    setup_options = sorted(set(trades["Setup"].dropna().unique()).union(SETUPS))

