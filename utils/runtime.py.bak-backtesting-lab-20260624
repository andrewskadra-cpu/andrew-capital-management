    target_value = sde * target_multiple
    next_year_revenue = annual_revenue * (1 + growth_rate_pct / 100)

    col3, col4, col5, col6 = st.columns(4)
    col3.metric("SDE", money(sde))
    col4.metric("Implied Multiple", f"{implied_multiple:.2f}x")
    col5.metric("Target Value", money(target_value))
    col6.metric("Next-Year Revenue", money(next_year_revenue))

    if sde <= 0:
        st.warning("SDE is zero or negative. Review the assumptions before moving forward.")
    elif implied_multiple <= target_multiple:
        st.success("The asking price is at or below the target multiple.")
    else:
        st.info("The asking price is above the target multiple.")

    st.divider()
    st.subheader("SBA Acquisition Financing Analysis")
    sba_col1, sba_col2 = st.columns(2)
    with sba_col1:
        sba_purchase_price = st.number_input(
            "Purchase Price",
            min_value=0.0,
            value=float(asking_price),
            step=10000.0,
            key="sba_purchase_price",
        )
        down_payment_pct = st.number_input(
            "Down Payment %",
            min_value=0.0,
            max_value=100.0,
            value=10.0,
            step=1.0,
            key="sba_down_payment_pct",
        )
    with sba_col2:
        sba_interest_rate = st.number_input(
            "SBA Interest Rate",
            min_value=0.0,
            value=10.5,
            step=0.25,
            key="sba_interest_rate",
        )
        loan_term = st.number_input(
            "Loan Term",
            min_value=1,
            value=10,
            step=1,
            key="sba_loan_term",
        )

    down_payment = sba_purchase_price * down_payment_pct / 100
    loan_amount = max(sba_purchase_price - down_payment, 0.0)
    sba_monthly_payment = monthly_payment(loan_amount, sba_interest_rate, loan_term)
    annual_debt_service = sba_monthly_payment * 12
    total_interest_paid = max((sba_monthly_payment * loan_term * 12) - loan_amount, 0.0)
    dscr = sde / annual_debt_service if annual_debt_service else 0.0
    cash_flow_after_debt = sde - annual_debt_service

    sba_metric1, sba_metric2, sba_metric3, sba_metric4 = st.columns(4)
    sba_metric1.metric("Loan Amount", money(loan_amount))
    sba_metric2.metric("Monthly Payment", money(sba_monthly_payment))
    sba_metric3.metric("Annual Debt Service", money(annual_debt_service))
    sba_metric4.metric("Total Interest Paid", money(total_interest_paid))

    sba_metric5, sba_metric6 = st.columns(2)
    sba_metric5.metric("DSCR", f"{dscr:.2f}x")
    sba_metric6.metric("Cash Flow After Debt", money(cash_flow_after_debt))

    if annual_debt_service <= 0:
        st.info("Enter a purchase price and loan terms to calculate SBA financing metrics.")
    elif dscr >= 1.50:
        st.success("Strong SBA candidate: DSCR is comfortably above lender coverage thresholds.")
    elif dscr >= 1.25:
        st.success("Acceptable SBA candidate: DSCR meets a typical minimum coverage target.")
    elif dscr >= 1.00:
        st.warning("Thin coverage: DSCR is positive but may be too tight for SBA approval without stronger cash flow or more equity.")
    else:
        st.error("Weak financing fit: DSCR is below 1.00, meaning projected cash flow does not cover annual debt service.")


def score_capital_opportunities(
    available_capital: float,
    target_return: float,
    risk_tolerance: str,
    investment_horizon: str,
) -> pd.DataFrame:
    risk_scores = {"Low": 30, "Medium": 60, "High": 90}
    horizon_scores = {"Short-Term": 90, "Medium-Term": 65, "Long-Term": 40}
    desired_risk = risk_scores.get(risk_tolerance, 60)
    desired_liquidity = horizon_scores.get(investment_horizon, 65)

    opportunities = [
        {
            "Opportunity": "Trading",
            "Expected ROI": 18.0,
            "Risk Level": 85,
            "Liquidity": 95,
            "Time Requirement": 85,
            "Scalability": 55,
            "Passive Income Potential": 10,
        },
        {
            "Opportunity": "Brokerage Investing",
            "Expected ROI": 9.0,
            "Risk Level": 45,
            "Liquidity": 90,
            "Time Requirement": 20,
            "Scalability": 80,
            "Passive Income Potential": 35,
        },
        {
            "Opportunity": "Retirement Accounts",
            "Expected ROI": 8.0,
            "Risk Level": 35,
            "Liquidity": 25,
            "Time Requirement": 15,
            "Scalability": 70,
            "Passive Income Potential": 30,
        },
        {
            "Opportunity": "Real Estate Investments",
            "Expected ROI": 14.0,
            "Risk Level": 60,
            "Liquidity": 35,
            "Time Requirement": 55,
            "Scalability": 75,
            "Passive Income Potential": 85,
        },
        {
            "Opportunity": "Business Acquisitions",
            "Expected ROI": 28.0,
            "Risk Level": 75,
            "Liquidity": 20,
            "Time Requirement": 80,
            "Scalability": 95,
            "Passive Income Potential": 75,
        },
        {
            "Opportunity": "Cash",
            "Expected ROI": 4.5,
            "Risk Level": 5,
            "Liquidity": 100,
            "Time Requirement": 5,
            "Scalability": 20,
            "Passive Income Potential": 15,
        },
    ]

    rows = []
    for item in opportunities:
        expected_return_score = min(item["Expected ROI"] / max(target_return, 1) * 100, 100)
        risk_fit = max(0, 100 - abs(item["Risk Level"] - desired_risk))
        liquidity_fit = max(0, 100 - abs(item["Liquidity"] - desired_liquidity))
        time_score = 100 - item["Time Requirement"]
        capital_fit = 100
        if item["Opportunity"] in ["Real Estate Investments", "Business Acquisitions"] and available_capital < 50000:
            capital_fit = 65
        if item["Opportunity"] == "Cash" and target_return > 8:
            capital_fit = 45

        score = (
            expected_return_score * 0.30
            + risk_fit * 0.20
            + liquidity_fit * 0.15
            + time_score * 0.10
            + item["Scalability"] * 0.15
            + item["Passive Income Potential"] * 0.10
        ) * (capital_fit / 100)

        recommendation = "Prioritize" if score >= 80 else "Consider" if score >= 65 else "Monitor" if score >= 50 else "Deprioritize"
        rows.append(
            {
                "Opportunity": item["Opportunity"],
                "Score": round(score, 1),
                "Expected ROI": item["Expected ROI"],
                "Risk Level": "High" if item["Risk Level"] >= 70 else "Medium" if item["Risk Level"] >= 35 else "Low",
                "Liquidity": "High" if item["Liquidity"] >= 70 else "Medium" if item["Liquidity"] >= 35 else "Low",
                "Recommendation": recommendation,
                "Time Requirement": item["Time Requirement"],
                "Scalability": item["Scalability"],
                "Passive Income Potential": item["Passive Income Potential"],
            }
        )

    return pd.DataFrame(rows).sort_values("Score", ascending=False)


def bounded_score(value: float, low: float = 0.0, high: float = 100.0, invert: bool = False) -> float:
    if high == low:
        score = 50.0
    else:
        score = (float(value) - low) / (high - low) * 100
    score = max(0.0, min(score, 100.0))
    return 100.0 - score if invert else score


def universal_risk_label(risk_score: float) -> str:
    if risk_score >= 70:
        return "High"
    if risk_score >= 35:
        return "Medium"
    return "Low"


def recommendation_from_score(score: float) -> str:
    if score >= 80:
        return "Prioritize"
    if score >= 65:
        return "Strong Candidate"
    if score >= 50:
        return "Monitor"
    return "Deprioritize"


