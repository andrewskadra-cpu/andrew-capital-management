def render_wealth_dashboard() -> None:
    st.title("Wealth Dashboard V1")
    st.caption("Complete net worth tracker for assets, liabilities, and account-level balances.")

    assets = read_wealth_accounts()
    liabilities = read_liabilities()

    with st.expander("Add or Update Asset Account", expanded=True):
        with st.form("asset_form", clear_on_submit=True):
            col1, col2, col3 = st.columns([1.3, 1, 1])
            account = col1.text_input("Asset Account Name")
            account_type = col2.selectbox("Asset Type", ACCOUNT_TYPES)
            balance = col3.number_input("Asset Balance", min_value=0.0, step=100.0)
            submitted = st.form_submit_button("Save Asset", type="primary")

            if submitted:
                if not account.strip():
                    st.error("Asset account name is required.")
                else:
                    updated = assets.copy()
                    match = updated["Account"].str.lower() == account.strip().lower()
                    if match.any():
                        updated.loc[match, "Account"] = account.strip()
                        updated.loc[match, "Type"] = account_type
                        updated.loc[match, "Balance"] = balance
                    else:
                        updated = pd.concat(
                            [
                                updated,
                                pd.DataFrame([{"Account": account.strip(), "Type": account_type, "Balance": balance}]),
                            ],
                            ignore_index=True,
                        )
                    save_wealth_accounts(updated)
                    st.success("Asset account saved.")
                    st.rerun()

    with st.expander("Add or Update Liability Account", expanded=False):
        with st.form("liability_form", clear_on_submit=True):
            col1, col2, col3 = st.columns([1.3, 1, 1])
            liability = col1.text_input("Liability Account Name")
            liability_type = col2.selectbox("Liability Type", LIABILITY_TYPES)
            balance = col3.number_input("Liability Balance", min_value=0.0, step=100.0)
