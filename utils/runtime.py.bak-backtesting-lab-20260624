    events = read_academy_events()
    journal = read_academy_journal()
    playbooks = read_academy_playbooks()
    backtests = read_academy_backtests()
    resources = read_academy_resources()
    completed_lessons = int(progress["Completed"].sum()) if not progress.empty else 0
    total_lessons = len(lessons)
    completion_pct = completed_lessons / total_lessons * 100 if total_lessons else 0.0
    journal_entries = len(journal)
    paper_trades = int((journal["Market"].astype(str).str.lower() == "paper").sum()) if not journal.empty else 0
    live_trades = max(journal_entries - paper_trades, 0)
    wins = int((journal["P&L"] > 0).sum()) if not journal.empty else 0
    win_rate = wins / journal_entries * 100 if journal_entries else 0.0
    avg_rr = journal["Risk Reward Ratio"].mean() if not journal.empty else 0.0
    current_month = pd.Timestamp.today().to_period("M")
    month_data = journal[pd.to_datetime(journal["Trade Date"], errors="coerce").dt.to_period("M") == current_month] if not journal.empty else journal
    monthly_pnl = month_data["P&L"].sum() if not month_data.empty else 0.0
    resources_completed = int((resources["Status"] == "Completed").sum()) if not resources.empty else 0
    xp = completed_lessons * 25 + journal_entries * 10 + len(backtests) * 50 + resources_completed * 15 + len(playbooks) * 20
    return {
        "lessons": lessons,
        "progress": progress,
        "events": events,
        "journal": journal,
        "playbooks": playbooks,
        "backtests": backtests,
        "resources": resources,
        "knowledge_score": min(100.0, completion_pct * 0.60 + min(journal_entries, 50) * 0.40),
        "completed_lessons": completed_lessons,
        "completion_pct": completion_pct,
        "journal_entries": journal_entries,
        "paper_trades": paper_trades,
        "live_trades": live_trades,
        "win_rate": win_rate,
        "avg_rr": avg_rr,
        "monthly_pnl": monthly_pnl,
        "xp": xp,
        "level": int(xp // 500) + 1,
    }


def academy_badges(metrics: dict[str, object]) -> list[str]:
    badges = []
    journal_entries = int(metrics["journal_entries"])
    if journal_entries >= 1:
        badges.append("First Journal Entry")
    if journal_entries >= 10:
        badges.append("10 Trades Logged")
    if journal_entries >= 100:
        badges.append("100 Trades Logged")
    if len(metrics["backtests"]) >= 1:
        badges.append("First Backtest")
    lessons = metrics["lessons"]
    progress = metrics["progress"]
    if not lessons.empty and not progress.empty:
        beginner_ids = set(lessons.loc[lessons["Category"] == "BEGINNER", "Lesson ID"])
        completed_ids = set(progress.loc[progress["Completed"], "Lesson ID"])
        if beginner_ids and beginner_ids.issubset(completed_ids):
            badges.append("Complete Beginner Curriculum")
    return badges


