def resolve_image_path(path_value: object) -> Path | None:
    if pd.isna(path_value):
        return None
    path_text = str(path_value).strip()
    if not path_text:
        return None

    candidate = Path(path_text)
    if not candidate.is_absolute():
        candidate = APP_DIR / candidate
    return candidate


def parse_checkbox_value(value: object) -> bool:
    if isinstance(value, bool):
        return value
    if pd.isna(value):
        return False
    if isinstance(value, (int, float)):
        return value != 0
    return str(value).strip().lower() in {"true", "1", "yes", "y", "checked"}


def grade_score(grade: str) -> int:
    return {"A+": 100, "A": 92, "B": 82, "C": 70, "D": 58, "F": 35}.get(str(grade).upper(), 70)


def emotion_score(emotion: str) -> int:
    return {
        "Focused": 100,
        "Confident": 92,
        "Neutral": 80,
        "Fearful": 62,
        "Frustrated": 55,
        "FOMO": 45,
        "Tired": 50,
    }.get(str(emotion), 80)


def calculate_compliance_score(row: pd.Series) -> int:
    violations = sum(1 for column in MISTAKE_COLUMNS if bool(row.get(column, False)))
    return max(0, 100 - violations * 10)


def calculate_trade_quality_score(row: pd.Series) -> int:
    rr = float(row.get("RR", 0) or 0)
    rr_component = min(rr / 3, 1) * 30
    compliance_component = calculate_compliance_score(row) * 0.35
    grade_component = grade_score(str(row.get("Grade", "C"))) * 0.25
    emotion_component = emotion_score(str(row.get("Emotional State", "Neutral"))) * 0.10
    return int(round(max(0, min(rr_component + compliance_component + grade_component + emotion_component, 100))))


