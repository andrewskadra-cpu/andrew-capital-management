@st.cache_data(ttl=300)
def fetch_market_snapshot(tickers: tuple[str, ...]) -> pd.DataFrame:
    if yf is None or not tickers:
        return pd.DataFrame(columns=["Ticker", "Current Price", "Daily Change %", "Daily Change", "Volume", "ATR", "52 Week High", "52 Week Low"])

    rows = []
    for ticker in tickers:
        try:
            data = yf.Ticker(ticker)
            history = data.history(period="1y")
            if history.empty:
                continue
            latest = history.iloc[-1]
            previous_close = history["Close"].iloc[-2] if len(history) > 1 else latest["Close"]
            daily_change = latest["Close"] - previous_close
            daily_change_pct = (daily_change / previous_close * 100) if previous_close else 0.0
            true_range = pd.concat(
                [
                    history["High"] - history["Low"],
                    (history["High"] - history["Close"].shift()).abs(),
                    (history["Low"] - history["Close"].shift()).abs(),
                ],
                axis=1,
            ).max(axis=1)
            atr = true_range.tail(14).mean() if not true_range.empty else 0.0
            rows.append(
                {
                    "Ticker": ticker,
                    "Current Price": float(latest["Close"]),
                    "Daily Change %": float(daily_change_pct),
                    "Daily Change": float(daily_change),
                    "Volume": float(latest.get("Volume", 0)),
                    "ATR": float(atr),
                    "52 Week High": float(history["High"].max()),
                    "52 Week Low": float(history["Low"].min()),
                }
            )
        except Exception:
            continue
    return pd.DataFrame(rows)


