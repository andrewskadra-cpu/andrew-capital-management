def render_academy_performance_analytics() -> None:
    journal = read_academy_journal()
    if journal.empty:
        st.info("No academy journal entries yet.")
        return
    data = journal.copy()
    data["Trade Date"] = pd.to_datetime(data["Trade Date"], errors="coerce")
    col1, col2, col3, col4 = st.columns(4)
    start_date = col1.date_input("Date Range Start", value=data["Trade Date"].min().date())
    end_date = col2.date_input("Date Range End", value=data["Trade Date"].max().date())
    strategies = sorted(data["Strategy"].dropna().unique())
    markets = sorted(data["Market"].dropna().unique())
    strategy_filter = col3.multiselect("Strategy", strategies, default=strategies)
    market_filter = col4.multiselect("Market", markets, default=markets)
    ticker_filter = st.multiselect("Ticker", sorted(data["Ticker"].dropna().unique()), default=sorted(data["Ticker"].dropna().unique()))
    filtered = data[(data["Trade Date"].dt.date >= start_date) & (data["Trade Date"].dt.date <= end_date)]
    if strategy_filter:
        filtered = filtered[filtered["Strategy"].isin(strategy_filter)]
    if market_filter:
        filtered = filtered[filtered["Market"].isin(market_filter)]
    if ticker_filter:
        filtered = filtered[filtered["Ticker"].isin(ticker_filter)]
    total = len(filtered)
    wins = int((filtered["P&L"] > 0).sum()) if total else 0
    gross_profit = filtered.loc[filtered["P&L"] > 0, "P&L"].sum()
    gross_loss = abs(filtered.loc[filtered["P&L"] < 0, "P&L"].sum())
    kpis = st.columns(6)
    kpis[0].metric("Total Trades", f"{total:,}")
    kpis[1].metric("Win Rate", percent(wins / total * 100 if total else 0.0))
    kpis[2].metric("Profit Factor", f"{gross_profit / gross_loss:.2f}" if gross_loss else "0.00")
    kpis[3].metric("Average R Multiple", f"{filtered['Risk Reward Ratio'].mean() if total else 0.0:.2f}")
    kpis[4].metric("Largest Win", money(filtered["P&L"].max() if total else 0.0))
    kpis[5].metric("Largest Loss", money(filtered["P&L"].min() if total else 0.0))
    st.metric("Average Hold Time", "Not tracked")
    monthly = filtered.groupby(filtered["Trade Date"].dt.to_period("M"))["P&L"].sum()
    monthly.index = monthly.index.astype(str)
    st.subheader("Monthly P&L")
    st.bar_chart(monthly)
    c1, c2 = st.columns(2)
    c1.subheader("Performance By Strategy")
    c1.bar_chart(filtered.groupby("Strategy")["P&L"].sum())
    c2.subheader("Performance By Market")
    c2.bar_chart(filtered.groupby("Market")["P&L"].sum())
    st.subheader("Trade Distribution")
    st.bar_chart(filtered["P&L"])


