                alt.Chart(pie_data)
                .mark_arc(innerRadius=45)
                .encode(
                    theta=alt.Theta(field="Balance", type="quantitative"),
                    color=alt.Color(field="Type", type="nominal", title="Asset Type"),
                    tooltip=[
                        alt.Tooltip("Type:N", title="Asset Type"),
                        alt.Tooltip("Balance:Q", title="Balance", format="$,.2f"),
