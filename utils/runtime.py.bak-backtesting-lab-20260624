    backtests = read_academy_backtests()
    with st.form("academy_backtest_form", clear_on_submit=True):
        col1, col2, col3 = st.columns(3)
        strategy_name = col1.text_input("Strategy Name")
        date_range = col2.text_input("Date Range")
        market = col3.text_input("Market")
        col4, col5, col6 = st.columns(3)
        sample_size = col4.number_input("Sample Size", min_value=0, step=1)
        wins = col5.number_input("Wins", min_value=0, step=1)
        losses = col6.number_input("Losses", min_value=0, step=1)
        col7, col8 = st.columns(2)
        average_gain = col7.number_input("Average Gain", min_value=0.0, step=10.0)
        average_loss = col8.number_input("Average Loss", min_value=0.0, step=10.0)
        total = wins + losses
        win_rate = wins / total * 100 if total else 0.0
        expectancy = (win_rate / 100 * average_gain) - ((1 - win_rate / 100) * average_loss)
        profit_factor = (wins * average_gain) / (losses * average_loss) if losses and average_loss else 0.0
        average_r_multiple = average_gain / average_loss if average_loss else 0.0
        st.info(f"Win Rate: {percent(win_rate)} | Expectancy: {money(expectancy)} | Profit Factor: {profit_factor:.2f} | Average R Multiple: {average_r_multiple:.2f}")
        if st.form_submit_button("Save Backtest", type="primary") and strategy_name.strip():
            row = {
                "Strategy Name": strategy_name.strip(),
                "Date Range": date_range,
                "Market": market,
                "Sample Size": sample_size,
                "Wins": wins,
                "Losses": losses,
                "Win Rate": win_rate,
                "Average Gain": average_gain,
                "Average Loss": average_loss,
                "Expectancy": expectancy,
                "Profit Factor": profit_factor,
                "Average R Multiple": average_r_multiple,
            }
            save_academy_backtests(pd.concat([backtests, pd.DataFrame([row])], ignore_index=True))
            st.success("Backtest saved.")
            st.rerun()
    if backtests.empty:
        st.info("No backtests saved yet.")
    else:
        c1, c2, c3 = st.columns(3)
        c1.caption("Win Rate Trend")
        c1.line_chart(backtests["Win Rate"])
