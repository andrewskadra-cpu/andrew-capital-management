def trade_analyzer_recommendation(score: float) -> str:
    if score >= 90:
        return "Strong Trade"
    if score >= 75:
        return "Good Trade"
    if score >= 60:
        return "Average Trade"
    return "Avoid Trade"


def trade_analyzer_rr_label(rr_ratio: float) -> str:
    if rr_ratio >= 3:
        return "Excellent"
    if rr_ratio >= 2:
        return "Good"
    if rr_ratio >= 1.5:
        return "Acceptable"
    return "Poor"


def trade_analyzer_color(score: float) -> str:
    if score >= 75:
        return "#16a34a"
    if score >= 60:
        return "#ca8a04"
    return "#dc2626"


def evaluate_trade_analyzer_setup(
    direction: str,
    entry: float,
    stop: float,
    target: float,
    account_size: float,
    position_size: float,
    setup_quality: int,
) -> dict[str, object]:
    bullish = direction == "Bullish"
    risk = abs(entry - stop) if entry and stop else 0.0
    reward = abs(target - entry) if entry and target else 0.0
    dollar_risk = risk * position_size
    potential_profit = reward * position_size
    account_risk_pct = dollar_risk / account_size * 100 if account_size else 0.0
    rr_ratio = reward / risk if risk else 0.0

    risk_score = 0.0
    if stop > 0:
        risk_score += 10
    if account_size > 0 and position_size > 0 and dollar_risk > 0:
        risk_score += 8
    if account_risk_pct <= 2 and account_risk_pct > 0:
        risk_score += 12
    elif account_risk_pct <= 3 and account_risk_pct > 0:
        risk_score += 7

    reward_score = min(rr_ratio / 3 * 25, 25)
    setup_score = setup_quality / 10 * 25
    structure_score = 0.0
    if entry > 0:
        structure_score += 5
    if bullish:
        if stop < entry:
            structure_score += 7.5
        if target > entry:
            structure_score += 7.5
    else:
        if stop > entry:
            structure_score += 7.5
        if target < entry:
            structure_score += 7.5

    score = round(max(0.0, min(risk_score + reward_score + setup_score + structure_score, 100.0)), 1)
    recommendation = trade_analyzer_recommendation(score)
    risk_rating = "Low" if account_risk_pct <= 1 else "Moderate" if account_risk_pct <= 2 else "High"

    strengths = []
    weaknesses = []
    if rr_ratio >= 2:
        strengths.append(f"Risk/reward is {trade_analyzer_rr_label(rr_ratio).lower()} at {rr_ratio:.2f}:1.")
    else:
        weaknesses.append(f"Risk/reward is only {rr_ratio:.2f}:1, below the preferred 2:1 standard.")
    if account_risk_pct <= 2 and account_risk_pct > 0:
        strengths.append(f"Account risk is controlled at {account_risk_pct:.2f}%.")
    else:
        weaknesses.append(f"Account risk is {account_risk_pct:.2f}%, above the 2% risk-management threshold.")
    if structure_score >= 20:
        strengths.append("Trade structure is logically aligned with direction, stop, and target.")
    else:
        weaknesses.append("Trade structure needs review: entry, stop, and target do not fully align with direction.")
    if setup_quality >= 8:
        strengths.append("User-selected setup quality is strong.")
    elif setup_quality <= 5:
        weaknesses.append("User-selected setup quality is weak.")

    risk_assessment = (
        f"The defined downside is {money(dollar_risk)} or {account_risk_pct:.2f}% of account size. "
        f"A failed setup would lose approximately {money(risk)} per share/contract."
    )
    final_verdict = (
        f"This setup is classified as {recommendation}. "
        f"It {'meets' if score >= 75 else 'does not fully meet'} disciplined risk-management standards because "
        f"the score is {score:.1f}/100 with a {rr_ratio:.2f}:1 risk/reward ratio and {risk_rating.lower()} risk."
    )

    return {
        "risk": risk,
        "dollar_risk": dollar_risk,
        "reward": reward,
        "potential_profit": potential_profit,
        "account_risk_pct": account_risk_pct,
        "rr_ratio": rr_ratio,
        "rr_label": trade_analyzer_rr_label(rr_ratio),
        "risk_score": risk_score,
        "reward_score": reward_score,
        "setup_score": setup_score,
        "structure_score": structure_score,
        "score": score,
        "recommendation": recommendation,
        "risk_rating": risk_rating,
        "strengths": strengths,
        "weaknesses": weaknesses,
        "risk_assessment": risk_assessment,
        "final_verdict": final_verdict,
    }


