        return pd.DataFrame(columns=[group_column, "Trades", "Win Rate", "Total Profit", "Average RR", "Expectancy"])

    grouped = (
        trades.groupby(group_column, dropna=False)
        .agg(
            Trades=(group_column, "size"),
            Wins=("Profit", lambda values: (values > 0).sum()),
            Total_Profit=("Profit", "sum"),
            Average_RR=("RR", "mean"),
            Expectancy=("Profit", "mean"),
        )
        .reset_index()
    )
    grouped["Win Rate"] = grouped["Wins"] / grouped["Trades"] * 100
    grouped = grouped.rename(columns={"Total_Profit": "Total Profit", "Average_RR": "Average RR"})
    return grouped.drop(columns=["Wins"]).sort_values("Total Profit", ascending=False)


def day_of_week_analysis(trades: pd.DataFrame) -> pd.DataFrame:
    if trades.empty:
        return pd.DataFrame(columns=["Day", "Trades", "Profit", "Win Rate"])

    data = trades.copy()
    data["Date"] = pd.to_datetime(data["Date"], errors="coerce")
    data = data.dropna(subset=["Date"])
    if data.empty:
        return pd.DataFrame(columns=["Day", "Trades", "Profit", "Win Rate"])

    data["Day"] = data["Date"].dt.day_name()
    result = (
        data.groupby("Day")
        .agg(Trades=("Day", "size"), Profit=("Profit", "sum"), Wins=("Profit", lambda values: (values > 0).sum()))
        .reset_index()
    )
    result["Win Rate"] = result["Wins"] / result["Trades"] * 100
    days = ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"]
    result["Day"] = pd.Categorical(result["Day"], categories=days, ordered=True)
    return result.drop(columns=["Wins"]).sort_values("Day")


