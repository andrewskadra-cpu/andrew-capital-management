def calculate_irr(cash_flows: list[float]) -> float:
    if not cash_flows or all(value >= 0 for value in cash_flows) or all(value <= 0 for value in cash_flows):
        return 0.0

    low = -0.95
    high = 5.0
    for _ in range(100):
        mid = (low + high) / 2
        npv = sum(cash_flow / ((1 + mid) ** period) for period, cash_flow in enumerate(cash_flows))
        if npv > 0:
            low = mid
        else:
            high = mid
    return (low + high) / 2 * 100


def enrich_real_estate_properties(properties: pd.DataFrame) -> pd.DataFrame:
    enriched = properties.copy()
    if enriched.empty:
        for column in [
            "Equity",
            "Annual Rent",
            "Effective Gross Income",
            "Operating Expenses",
            "NOI",
            "Annual Debt Service",
            "Cash Flow",
            "Cap Rate",
            "DSCR",
            "Cash on Cash Return",
            "IRR",
            "ROI",
        ]:
            enriched[column] = []
        return enriched

    enriched["Equity"] = enriched["Current Value"] - enriched["Mortgage Balance"]
    enriched["Annual Rent"] = enriched["Monthly Rent"] * 12
    enriched["Effective Gross Income"] = enriched["Annual Rent"] * (1 - enriched["Vacancy %"] / 100)
    enriched["Operating Expenses"] = (
        enriched["Annual Taxes"]
        + enriched["Insurance"]
        + enriched["CapEx Reserve"]
        + enriched["Maintenance Reserve"]
        + (enriched["Effective Gross Income"] * enriched["Management Fee"] / 100)
    )
    enriched["NOI"] = enriched["Effective Gross Income"] - enriched["Operating Expenses"]
    enriched["Annual Debt Service"] = enriched.apply(
        lambda row: monthly_payment(float(row["Mortgage Balance"]), float(row["Interest Rate"]), int(row["Loan Term"])) * 12
        if float(row["Mortgage Balance"]) > 0 and int(row["Loan Term"]) > 0
        else 0.0,
        axis=1,
    )
    enriched["Cash Flow"] = enriched["NOI"] - enriched["Annual Debt Service"]
    enriched["Cap Rate"] = enriched.apply(
        lambda row: (row["NOI"] / row["Current Value"] * 100) if row["Current Value"] else 0.0,
        axis=1,
    )
    enriched["DSCR"] = enriched.apply(
        lambda row: (row["NOI"] / row["Annual Debt Service"]) if row["Annual Debt Service"] else 0.0,
        axis=1,
    )
    enriched["Cash Invested"] = (enriched["Purchase Price"] - enriched["Mortgage Balance"]).clip(lower=0)
    enriched["Cash on Cash Return"] = enriched.apply(
        lambda row: (row["Cash Flow"] / row["Cash Invested"] * 100) if row["Cash Invested"] else 0.0,
        axis=1,
    )
    enriched["ROI"] = enriched.apply(
        lambda row: ((row["Equity"] - row["Cash Invested"] + row["Cash Flow"]) / row["Cash Invested"] * 100)
        if row["Cash Invested"]
        else 0.0,
        axis=1,
    )
    enriched["IRR"] = enriched.apply(
        lambda row: calculate_irr(
            [
                -float(row["Cash Invested"]),
                float(row["Cash Flow"]),
                float(row["Cash Flow"]),
                float(row["Cash Flow"]),
                float(row["Cash Flow"]),
                float(row["Cash Flow"]) + (float(row["Current Value"]) * (1.03**5) - float(row["Mortgage Balance"])),
            ]
        )
        if float(row["Cash Invested"]) > 0
        else 0.0,
        axis=1,
    )
    return enriched


