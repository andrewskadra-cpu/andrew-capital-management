def executive_report_pdf(report_df: pd.DataFrame, metadata: dict[str, object]) -> bytes | None:
    def pdf_escape(value: object) -> str:
        return str(value).replace("\\", "\\\\").replace("(", "\\(").replace(")", "\\)")

    if SimpleDocTemplate is None:
        lines = [
            f"{metadata['report_type']} - Andrew Capital Management",
            str(metadata["summary"]),
            "",
            "Board Report Metrics",
        ]
        for _, row in report_df.iterrows():
