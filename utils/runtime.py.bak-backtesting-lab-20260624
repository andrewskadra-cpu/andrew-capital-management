def build_universal_opportunity_scores() -> pd.DataFrame:
    rows: list[dict[str, object]] = []

    trades = read_trades()
    for index, trade in trades.iterrows():
        entry_capital = float(trade["Entry"]) * float(trade["Shares"])
        expected_roi = (float(trade["Profit"]) / entry_capital * 100) if entry_capital else 0.0
        mistake_count = sum(1 for column in MISTAKE_COLUMNS if bool(trade.get(column, False)))
        compliance = float(trade.get("Compliance Score", 70.0))
        quality = float(trade.get("Trade Quality Score", 70.0))
        risk = max(10.0, min(100.0, 100.0 - compliance + mistake_count * 8.0 + (20.0 if float(trade["Profit"]) < 0 else 0.0)))
        ticker = str(trade.get("Ticker", "") or "Unknown")
        setup = str(trade.get("Setup", "") or "Unspecified")
        trade_date = trade.get("Date", "")
        rows.append(
            {
                "Opportunity Type": "Trade",
                "Opportunity": f"{ticker} - {setup} - {trade_date}",
                "Score Name": "Trade Score",
                "Expected ROI": expected_roi,
                "Risk": risk,
                "Raw Cash Flow": float(trade["Profit"]),
                "Growth Potential": quality,
                "Liquidity": 95.0,
                "Management Complexity": 82.0,
            }
        )

    properties = enrich_real_estate_properties(read_real_estate_properties())
    for _, property_row in properties.iterrows():
        current_value = float(property_row["Current Value"])
        purchase_price = float(property_row["Purchase Price"])
        cash_flow = float(property_row["Cash Flow"])
        appreciation = ((current_value - purchase_price) / purchase_price * 100) if purchase_price else 0.0
        expected_roi = float(property_row["Cap Rate"]) + max(appreciation, 0.0) * 0.25
        risk = 45.0 + (15.0 if cash_flow < 0 else 0.0) + (10.0 if float(property_row["Mortgage Balance"]) > current_value * 0.8 else 0.0)
        rows.append(
            {
                "Opportunity Type": "Property",
                "Opportunity": str(property_row["Property Name"] or "Unnamed Property"),
                "Score Name": "Property Score",
                "Expected ROI": expected_roi,
                "Risk": min(risk, 100.0),
                "Raw Cash Flow": cash_flow,
                "Growth Potential": bounded_score(appreciation, -10.0, 30.0),
                "Liquidity": 25.0,
                "Management Complexity": 58.0,
            }
        )

    deals = read_acquisition_deals()
    for _, deal in deals.iterrows():
        asking_price = float(deal["Asking Price"])
        ebitda = float(deal["EBITDA"])
        expected_roi = (ebitda / asking_price * 100) if asking_price else 0.0
        multiple = float(deal["Multiple"])
        growth = bounded_score(expected_roi, 0.0, 40.0)
        if multiple and multiple <= 4:
            growth = min(100.0, growth + 10.0)
        rows.append(
            {
                "Opportunity Type": "Acquisition",
                "Opportunity": str(deal["Company Name"] or "Unnamed Deal"),
                "Score Name": "Acquisition Score",
                "Expected ROI": expected_roi,
                "Risk": acquisition_status_risk(str(deal["Status"])),
                "Raw Cash Flow": ebitda,
                "Growth Potential": growth,
                "Liquidity": 15.0,
                "Management Complexity": 88.0,
            }
        )

    accounts = read_wealth_accounts()
    for _, account in accounts.iterrows():
        account_type = str(account["Type"])
        balance = float(account["Balance"])
        assumptions = investment_account_assumptions(account_type)
        expected_roi = assumptions["roi"]
        rows.append(
            {
                "Opportunity Type": "Investment Account",
                "Opportunity": str(account["Account"] or account_type or "Unnamed Account"),
                "Score Name": "Investment Score",
                "Expected ROI": expected_roi,
                "Risk": assumptions["risk"],
                "Raw Cash Flow": balance * expected_roi / 100,
                "Growth Potential": assumptions["growth"],
                "Liquidity": assumptions["liquidity"],
                "Management Complexity": assumptions["complexity"],
            }
        )

    if not rows:
        return pd.DataFrame(
            columns=[
                "Opportunity Type",
                "Opportunity",
                "Score Name",
                "Score",
                "Expected ROI",
                "Risk",
                "Risk Level",
                "Cash Flow",
                "Growth Potential",
                "Liquidity",
                "Management Complexity",
                "Recommendation",
            ]
        )

    leaderboard = pd.DataFrame(rows)
    max_abs_cash_flow = max(float(leaderboard["Raw Cash Flow"].abs().max()), 1.0)
    leaderboard["Expected Return Score"] = leaderboard["Expected ROI"].apply(lambda value: bounded_score(value, -10.0, 35.0))
    leaderboard["Risk Control Score"] = leaderboard["Risk"].apply(lambda value: bounded_score(value, 0.0, 100.0, invert=True))
    leaderboard["Cash Flow Score"] = leaderboard["Raw Cash Flow"].apply(
        lambda value: bounded_score(value, -max_abs_cash_flow, max_abs_cash_flow)
    )
    leaderboard["Growth Score"] = leaderboard["Growth Potential"].apply(lambda value: bounded_score(value, 0.0, 100.0))
    leaderboard["Liquidity Score"] = leaderboard["Liquidity"].apply(lambda value: bounded_score(value, 0.0, 100.0))
    leaderboard["Complexity Score"] = leaderboard["Management Complexity"].apply(
        lambda value: bounded_score(value, 0.0, 100.0, invert=True)
    )
    leaderboard["Score"] = (
        leaderboard["Expected Return Score"] * 0.25
        + leaderboard["Risk Control Score"] * 0.20
        + leaderboard["Cash Flow Score"] * 0.15
        + leaderboard["Growth Score"] * 0.15
        + leaderboard["Liquidity Score"] * 0.10
        + leaderboard["Complexity Score"] * 0.15
    ).round(1)
    leaderboard["Risk Level"] = leaderboard["Risk"].apply(universal_risk_label)
    leaderboard["Cash Flow"] = leaderboard["Raw Cash Flow"]
    leaderboard["Recommendation"] = leaderboard["Score"].apply(recommendation_from_score)
    return leaderboard.sort_values(["Score", "Expected ROI"], ascending=[False, False]).reset_index(drop=True)


def cio_goal_progress(
    net_worth: float,
    trading_pnl: float,
    properties: pd.DataFrame,
    real_estate_equity: float,
    deals: pd.DataFrame,
) -> pd.DataFrame:
    closed_deals = int((deals["Status"] == "Closed").sum()) if not deals.empty else 0
    qualified_deals = int(deals["Status"].isin(["NDA", "CIM", "LOI", "Due Diligence", "Closed"]).sum()) if not deals.empty else 0
    income_properties = int((properties["Current Value"] > 0).sum()) if not properties.empty else 0
    rows = [
        {"Goal": "Financial Independence", "Current": net_worth, "Target": 1_000_000.0, "Display": money(net_worth)},
        {"Goal": "Annual Trading P&L", "Current": trading_pnl, "Target": 100_000.0, "Display": money(trading_pnl)},
        {"Goal": "First Rental Property", "Current": float(income_properties), "Target": 1.0, "Display": f"{income_properties:,} property"},
        {"Goal": "Real Estate Equity", "Current": real_estate_equity, "Target": 250_000.0, "Display": money(real_estate_equity)},
        {"Goal": "First Acquisition", "Current": float(closed_deals), "Target": 1.0, "Display": f"{closed_deals:,} closed"},
        {"Goal": "Qualified Deal Flow", "Current": float(qualified_deals), "Target": 5.0, "Display": f"{qualified_deals:,} qualified"},
    ]
    goals = pd.DataFrame(rows)
    goals["Progress"] = goals.apply(lambda row: clamp_progress(float(row["Current"]), float(row["Target"])) * 100, axis=1)
    return goals


