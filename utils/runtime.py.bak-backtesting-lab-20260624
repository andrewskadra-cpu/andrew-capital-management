def summarize_trades(trades: pd.DataFrame) -> dict[str, float]:
    total_trades = len(trades)
    total_profit = trades["Profit"].sum() if total_trades else 0.0
    winners = trades[trades["Profit"] > 0]
    losers = trades[trades["Profit"] < 0]
    win_rate = len(winners) / total_trades * 100 if total_trades else 0.0
    return {
        "total_trades": total_trades,
        "total_profit": total_profit,
        "win_rate": win_rate,
        "avg_rr": trades["RR"].mean() if total_trades else 0.0,
        "best_trade": trades["Profit"].max() if total_trades else 0.0,
        "worst_trade": trades["Profit"].min() if total_trades else 0.0,
        "avg_winner": winners["Profit"].mean() if not winners.empty else 0.0,
        "avg_loser": losers["Profit"].mean() if not losers.empty else 0.0,
    }


def advanced_trade_metrics(trades: pd.DataFrame) -> dict[str, float]:
    if trades.empty:
        return {
            "expectancy": 0.0,
            "profit_factor": 0.0,
            "sharpe_ratio": 0.0,
            "avg_holding_profit": 0.0,
            "avg_holding_loss": 0.0,
            "largest_winner": 0.0,
            "largest_loser": 0.0,
            "current_drawdown": 0.0,
            "max_drawdown": 0.0,
            "consecutive_wins": 0,
            "consecutive_losses": 0,
        }

    ordered = trades.sort_values("Date").copy()
    winners = ordered[ordered["Profit"] > 0]
    losers = ordered[ordered["Profit"] < 0]
    gross_profit = winners["Profit"].sum()
    gross_loss = abs(losers["Profit"].sum())
    equity = ordered["Profit"].cumsum()
    running_peak = equity.cummax()
    drawdown = equity - running_peak
    returns = ordered["Profit"]
    sharpe_ratio = 0.0
    if len(returns) > 1 and returns.std() != 0:
        sharpe_ratio = (returns.mean() / returns.std()) * (len(returns) ** 0.5)

    max_wins = max_losses = current_wins = current_losses = 0
    for value in ordered["Profit"]:
        if value > 0:
            current_wins += 1
            current_losses = 0
        elif value < 0:
            current_losses += 1
            current_wins = 0
        else:
            current_wins = 0
            current_losses = 0
        max_wins = max(max_wins, current_wins)
        max_losses = max(max_losses, current_losses)

    return {
        "expectancy": ordered["Profit"].mean(),
        "profit_factor": gross_profit / gross_loss if gross_loss else 0.0,
        "sharpe_ratio": sharpe_ratio,
        "avg_holding_profit": winners["Profit"].mean() if not winners.empty else 0.0,
        "avg_holding_loss": losers["Profit"].mean() if not losers.empty else 0.0,
        "largest_winner": ordered["Profit"].max(),
        "largest_loser": ordered["Profit"].min(),
        "current_drawdown": drawdown.iloc[-1] if len(drawdown) else 0.0,
        "max_drawdown": drawdown.min() if len(drawdown) else 0.0,
        "consecutive_wins": max_wins,
        "consecutive_losses": max_losses,
    }


def trading_equity_curves(trades: pd.DataFrame) -> dict[str, pd.DataFrame]:
    if trades.empty:
        empty = pd.DataFrame(columns=["Period", "Profit", "Equity"])
        return {"daily": empty, "weekly": empty, "monthly": empty}

    data = trades.copy()
    data["Date"] = pd.to_datetime(data["Date"], errors="coerce")
    data = data.dropna(subset=["Date"]).sort_values("Date")
    if data.empty:
        empty = pd.DataFrame(columns=["Period", "Profit", "Equity"])
        return {"daily": empty, "weekly": empty, "monthly": empty}

    def build_curve(freq: str) -> pd.DataFrame:
        curve = data.groupby(pd.Grouper(key="Date", freq=freq))["Profit"].sum().reset_index()
        curve = curve.rename(columns={"Date": "Period"})
        curve["Equity"] = curve["Profit"].cumsum()
        return curve

    return {"daily": build_curve("D"), "weekly": build_curve("W"), "monthly": build_curve("ME")}


def drawdown_statistics(equity_curve: pd.DataFrame) -> dict[str, float]:
    if equity_curve.empty or "Equity" not in equity_curve.columns:
        return {"max_drawdown": 0.0, "current_drawdown": 0.0, "recovery_time": 0}

    curve = equity_curve.copy().sort_values("Period")
    curve["Peak"] = curve["Equity"].cummax()
    curve["Drawdown"] = curve["Equity"] - curve["Peak"]
    max_drawdown = float(curve["Drawdown"].min()) if not curve.empty else 0.0
    current_drawdown = float(curve["Drawdown"].iloc[-1]) if not curve.empty else 0.0

    recovery_time = 0
    if max_drawdown < 0:
        trough_index = curve["Drawdown"].idxmin()
        prior_peak = float(curve.loc[:trough_index, "Peak"].max())
        trough_period = curve.loc[trough_index, "Period"]
        recovered = curve[(curve["Period"] > trough_period) & (curve["Equity"] >= prior_peak)]
        if not recovered.empty:
            recovery_time = int((recovered.iloc[0]["Period"] - trough_period).days)

    return {
        "max_drawdown": max_drawdown,
        "current_drawdown": current_drawdown,
        "recovery_time": recovery_time,
    }


def risk_of_ruin_probability(win_rate: float, rr_ratio: float, risk_per_trade: float) -> float:
    p_win = max(0.0, min(win_rate / 100, 1.0))
    p_loss = 1 - p_win
    rr_ratio = max(rr_ratio, 0.0)
    risk_per_trade = max(risk_per_trade, 0.01)
    edge = p_win * rr_ratio - p_loss
    if edge <= 0:
        return 100.0
    risk_units = max(1.0, 100.0 / risk_per_trade)
    denominator = max(p_win * rr_ratio, 0.0001)
    probability = (p_loss / denominator) ** risk_units
    return max(0.0, min(probability * 100, 100.0))


def monthly_performance_calendar(trades: pd.DataFrame, selected_month: pd.Timestamp) -> pd.DataFrame:
    month_start = selected_month.replace(day=1)
    month_end = month_start + pd.offsets.MonthEnd(1)
    days = pd.date_range(month_start, month_end, freq="D")
    calendar = pd.DataFrame({"Date": days})
    calendar["Day"] = calendar["Date"].dt.day
    calendar["Week"] = calendar["Date"].dt.isocalendar().week.astype(int)
    calendar["Weekday"] = calendar["Date"].dt.weekday

    data = trades.copy()
    data["Date"] = pd.to_datetime(data["Date"], errors="coerce")
    daily = data.dropna(subset=["Date"]).groupby(data["Date"].dt.date)["Profit"].sum()
    calendar["Profit"] = calendar["Date"].dt.date.map(daily).fillna(0.0)
    calendar["Display"] = calendar.apply(lambda row: f"{int(row['Day'])}\n{money(float(row['Profit']))}", axis=1)
    pivot = calendar.pivot(index="Week", columns="Weekday", values="Display").reindex(columns=range(7))
    pivot.columns = ["Mon", "Tue", "Wed", "Thu", "Fri", "Sat", "Sun"]
    profit_pivot = calendar.pivot(index="Week", columns="Weekday", values="Profit").reindex(columns=range(7))
    profit_pivot.columns = pivot.columns
    return pivot, profit_pivot


def run_trading_monte_carlo(
    trades: pd.DataFrame,
    starting_equity: float,
    simulations: int = 1000,
    trade_count: int | None = None,
) -> tuple[pd.DataFrame, pd.DataFrame]:
    profits = trades["Profit"].dropna().astype(float).tolist()
    if not profits:
        return pd.DataFrame(), pd.DataFrame()

    trade_count = trade_count or max(len(profits), 30)
    paths = []
    summaries = []
    for simulation in range(simulations):
        equity = float(starting_equity)
        peak = equity
        worst_drawdown = 0.0
        sampled = [random.choice(profits) for _ in range(trade_count)]
        for trade_number, profit in enumerate(sampled, start=1):
            equity += profit
            peak = max(peak, equity)
            worst_drawdown = min(worst_drawdown, equity - peak)
            paths.append({"Simulation": simulation, "Trade": trade_number, "Equity": equity})
        summaries.append({"Simulation": simulation, "Final Equity": equity, "Worst Drawdown": worst_drawdown})

    path_df = pd.DataFrame(paths)
    bands = (
        path_df.groupby("Trade")["Equity"]
        .quantile([0.1, 0.5, 0.9])
        .unstack()
        .reset_index()
        .rename(columns={0.1: "Worst Case", 0.5: "Expected Case", 0.9: "Best Case"})
    )
    return bands, pd.DataFrame(summaries)


def a_plus_setup_analysis(trades: pd.DataFrame) -> pd.DataFrame:
    if trades.empty:
        return pd.DataFrame(columns=["Setup", "Trades", "Win Rate", "Average RR", "Expectancy", "Total Profit"])

    a_plus = trades[trades["Grade"] == "A+"]
    if a_plus.empty:
        return pd.DataFrame(columns=["Setup", "Trades", "Win Rate", "Average RR", "Expectancy", "Total Profit"])

    analysis = (
        a_plus.groupby("Setup", dropna=False)
        .agg(
            Trades=("Setup", "size"),
            Wins=("Profit", lambda values: (values > 0).sum()),
            Average_RR=("RR", "mean"),
            Expectancy=("Profit", "mean"),
            Total_Profit=("Profit", "sum"),
        )
        .reset_index()
    )
    analysis["Win Rate"] = analysis["Wins"] / analysis["Trades"] * 100
    return analysis.rename(columns={"Average_RR": "Average RR", "Total_Profit": "Total Profit"}).drop(columns=["Wins"]).sort_values(
        "Expectancy", ascending=False
    )


def grouped_trade_analysis(trades: pd.DataFrame, group_column: str) -> pd.DataFrame:
