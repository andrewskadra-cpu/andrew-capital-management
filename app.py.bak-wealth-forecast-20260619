        return pd.DataFrame(columns=["Compliance Group", "Trades", "Total Profit", "Average Profit", "Win Rate"])

    data = trades.copy()
    data["Compliance Group"] = data["Compliance Score"].apply(lambda score: "High Compliance" if score >= 80 else "Low Compliance")
    grouped = (
        data.groupby("Compliance Group")
        .agg(
            Trades=("Compliance Group", "size"),
            Total_Profit=("Profit", "sum"),
            Average_Profit=("Profit", "mean"),
            Wins=("Profit", lambda values: (values > 0).sum()),
        )
        .reset_index()
    )
    grouped["Win Rate"] = grouped["Wins"] / grouped["Trades"] * 100
    return grouped.rename(columns={"Total_Profit": "Total Profit", "Average_Profit": "Average Profit"}).drop(columns=["Wins"])


