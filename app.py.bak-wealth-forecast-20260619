def trade_coach_summary(trades: pd.DataFrame, period_days: int | None = None) -> dict[str, object]:
    if trades.empty:
        return {
            "data": trades,
            "profit": 0.0,
            "win_rate": 0.0,
            "expectancy": 0.0,
            "best_setup": "N/A",
            "worst_setup": "N/A",
            "expensive_mistake": "N/A",
            "best_emotion": "N/A",
            "weaknesses": ["No trade data available yet."],
            "strengths": ["Start logging trades consistently."],
            "trader_score": 0,
        }

    data = trades.copy()
    data["Date"] = pd.to_datetime(data["Date"], errors="coerce")
    if period_days is not None:
        data = data[data["Date"] >= pd.Timestamp.today() - pd.Timedelta(days=period_days)]
    data = data.dropna(subset=["Date"])

    if data.empty:
        return trade_coach_summary(pd.DataFrame())

    summary = summarize_trades(data)
    setup_stats = setup_performance(data)
    mistake_stats = mistake_analysis(data)
    emotion_stats = grouped_trade_analysis(data, "Emotional State")
    compliance = data["Compliance Score"].mean()
    quality = data["Trade Quality Score"].mean()
    profit_factor = advanced_trade_metrics(data)["profit_factor"]

    best_setup = str(setup_stats.iloc[0]["Setup"]) if not setup_stats.empty else "N/A"
    worst_setup = str(setup_stats.iloc[-1]["Setup"]) if not setup_stats.empty else "N/A"
    expensive_mistake = str(mistake_stats.iloc[0]["Mistake"]) if not mistake_stats.empty and mistake_stats.iloc[0]["Count"] > 0 else "N/A"
    best_emotion = str(emotion_stats.iloc[0]["Emotional State"]) if not emotion_stats.empty else "N/A"

    strengths = []
    weaknesses = []
    if summary["win_rate"] >= 50:
        strengths.append("Win rate is above 50%.")
    else:
        weaknesses.append("Win rate is below 50%; review entry quality and selectivity.")
    if profit_factor >= 1.5:
        strengths.append("Profit factor shows a positive edge.")
    else:
        weaknesses.append("Profit factor is below 1.5; losses are consuming too much gross profit.")
    if compliance >= 80:
        strengths.append("Rule compliance is strong.")
    else:
        weaknesses.append("Compliance score is low; reduce rule violations before increasing size.")
    if quality >= 75:
        strengths.append("Trade quality score is healthy.")
    else:
        weaknesses.append("Trade quality needs improvement through better RR, discipline, and emotional control.")
    if expensive_mistake != "N/A":
        weaknesses.append(f"Most expensive mistake: {expensive_mistake}.")

    trader_score = int(round(min(max((summary["win_rate"] * 0.25) + (min(profit_factor, 3) / 3 * 25) + (compliance * 0.25) + (quality * 0.25), 0), 100)))

    return {
        "data": data,
        "profit": summary["total_profit"],
        "win_rate": summary["win_rate"],
        "expectancy": advanced_trade_metrics(data)["expectancy"],
        "best_setup": best_setup,
        "worst_setup": worst_setup,
        "expensive_mistake": expensive_mistake,
        "best_emotion": best_emotion,
        "weaknesses": weaknesses or ["No major weaknesses detected in this period."],
        "strengths": strengths or ["No clear strengths detected yet; keep building sample size."],
        "trader_score": trader_score,
    }


def render_ai_trade_coach(trades: pd.DataFrame) -> None:
    st.subheader("AI Trade Coach")
    st.caption("Rule-based coach that reviews trade history, grades, mistakes, setups, and psychology.")

    weekly = trade_coach_summary(trades, period_days=7)
    monthly = trade_coach_summary(trades, period_days=30)
    overall = trade_coach_summary(trades)

    col1, col2, col3 = st.columns(3)
    col1.metric("Trader Score", f"{overall['trader_score']}/100")
    col2.metric("Most Profitable Setup", str(overall["best_setup"]))
    col3.metric("Most Expensive Mistake", str(overall["expensive_mistake"]))

    st.subheader("Weekly Review")
    st.write(f"Profit: {money(float(weekly['profit']))} | Win Rate: {percent(float(weekly['win_rate']))} | Expectancy: {money(float(weekly['expectancy']))}")
    st.markdown("**Strengths**")
    for item in weekly["strengths"]:
        st.write(f"- {item}")
    st.markdown("**Weaknesses**")
    for item in weekly["weaknesses"]:
        st.write(f"- {item}")

    st.subheader("Monthly Review")
    st.write(f"Profit: {money(float(monthly['profit']))} | Win Rate: {percent(float(monthly['win_rate']))} | Expectancy: {money(float(monthly['expectancy']))}")
    st.write(f"Best setup: {monthly['best_setup']}")
    st.write(f"Least profitable setup: {monthly['worst_setup']}")
    st.write(f"Most profitable emotion: {monthly['best_emotion']}")

    st.subheader("Coach Action Plan")
    if overall["trader_score"] >= 80:
        st.success("Performance is strong. Focus on consistency, sizing discipline, and only scaling your best setups.")
    elif overall["trader_score"] >= 60:
        st.warning("Performance is developing. Focus on eliminating the top mistake and taking only A/B quality trades.")
    else:
        st.error("Performance needs stabilization. Reduce size, tighten rules, and rebuild around your best setup.")

