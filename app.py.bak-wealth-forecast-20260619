def calculate_profit(direction: str, entry: float, exit_price: float, shares: float) -> float:
    if direction == "Short":
        return (entry - exit_price) * shares
    return (exit_price - entry) * shares


def calculate_rr(entry: float, stop: float, target: float) -> float:
    risk = abs(entry - stop)
    reward = abs(target - entry)
    return reward / risk if risk > 0 else 0.0


def filter_trade_history(trades: pd.DataFrame, key_prefix: str) -> pd.DataFrame:
    if trades.empty:
        st.info("No trades entered yet.")
        return trades

    ticker_options = sorted(ticker for ticker in trades["Ticker"].dropna().unique() if ticker)
    setup_options = sorted(set(trades["Setup"].dropna().unique()).union(SETUPS))

    col1, col2, col3 = st.columns([1, 1, 1.2])
    with col1:
        selected_tickers = st.multiselect(
            "History Filter: Ticker",
            options=ticker_options,
            default=ticker_options,
            key=f"{key_prefix}_ticker_filter",
        )
    with col2:
        selected_setups = st.multiselect(
            "History Filter: Setup",
            options=setup_options,
            default=setup_options,
            key=f"{key_prefix}_setup_filter",
        )
    with col3:
        valid_dates = trades["Date"].dropna()
        if valid_dates.empty:
            selected_dates = None
            st.caption("No valid dates available.")
        else:
            selected_dates = st.date_input(
                "History Filter: Date Range",
                value=(valid_dates.min(), valid_dates.max()),
                min_value=valid_dates.min(),
                max_value=valid_dates.max(),
                key=f"{key_prefix}_date_filter",
            )

    filtered = trades.copy()
    if selected_tickers:
        filtered = filtered[filtered["Ticker"].isin(selected_tickers)]
    if selected_setups:
        filtered = filtered[filtered["Setup"].isin(selected_setups)]
    if isinstance(selected_dates, tuple) and len(selected_dates) == 2:
        start_date, end_date = selected_dates
        filtered = filtered[(filtered["Date"] >= start_date) & (filtered["Date"] <= end_date)]
    return filtered


def summarize_trades(trades: pd.DataFrame) -> dict[str, float]:
    total_trades = len(trades)
    total_profit = trades["Profit"].sum() if total_trades else 0.0
    winners = trades[trades["Profit"] > 0]
    losers = trades[trades["Profit"] < 0]
    win_rate = len(winners) / total_trades * 100 if total_trades else 0.0
    return {
        "total_trades": total_trades,
        "total_profit": total_profit,
        "win_rate": win_rate,
        "avg_rr": trades["RR"].mean() if total_trades else 0.0,
        "best_trade": trades["Profit"].max() if total_trades else 0.0,
        "worst_trade": trades["Profit"].min() if total_trades else 0.0,
        "avg_winner": winners["Profit"].mean() if not winners.empty else 0.0,
        "avg_loser": losers["Profit"].mean() if not losers.empty else 0.0,
    }


def advanced_trade_metrics(trades: pd.DataFrame) -> dict[str, float]:
    if trades.empty:
        return {
            "expectancy": 0.0,
            "profit_factor": 0.0,
            "sharpe_ratio": 0.0,
            "avg_holding_profit": 0.0,
            "avg_holding_loss": 0.0,
            "largest_winner": 0.0,
            "largest_loser": 0.0,
            "current_drawdown": 0.0,
            "max_drawdown": 0.0,
            "consecutive_wins": 0,
            "consecutive_losses": 0,
        }

    ordered = trades.sort_values("Date").copy()
    winners = ordered[ordered["Profit"] > 0]
    losers = ordered[ordered["Profit"] < 0]
    gross_profit = winners["Profit"].sum()
    gross_loss = abs(losers["Profit"].sum())
    equity = ordered["Profit"].cumsum()
    running_peak = equity.cummax()
    drawdown = equity - running_peak
    returns = ordered["Profit"]
    sharpe_ratio = 0.0
    if len(returns) > 1 and returns.std() != 0:
        sharpe_ratio = (returns.mean() / returns.std()) * (len(returns) ** 0.5)

    max_wins = max_losses = current_wins = current_losses = 0
    for value in ordered["Profit"]:
        if value > 0:
            current_wins += 1
            current_losses = 0
        elif value < 0:
            current_losses += 1
            current_wins = 0
        else:
            current_wins = 0
            current_losses = 0
        max_wins = max(max_wins, current_wins)
        max_losses = max(max_losses, current_losses)

    return {
        "expectancy": ordered["Profit"].mean(),
        "profit_factor": gross_profit / gross_loss if gross_loss else 0.0,
        "sharpe_ratio": sharpe_ratio,
        "avg_holding_profit": winners["Profit"].mean() if not winners.empty else 0.0,
        "avg_holding_loss": losers["Profit"].mean() if not losers.empty else 0.0,
        "largest_winner": ordered["Profit"].max(),
        "largest_loser": ordered["Profit"].min(),
        "current_drawdown": drawdown.iloc[-1] if len(drawdown) else 0.0,
        "max_drawdown": drawdown.min() if len(drawdown) else 0.0,
        "consecutive_wins": max_wins,
        "consecutive_losses": max_losses,
    }


def grouped_trade_analysis(trades: pd.DataFrame, group_column: str) -> pd.DataFrame:
    if trades.empty or group_column not in trades.columns:
        return pd.DataFrame(columns=[group_column, "Trades", "Win Rate", "Total Profit", "Average RR", "Expectancy"])

    grouped = (
        trades.groupby(group_column, dropna=False)
        .agg(
            Trades=(group_column, "size"),
            Wins=("Profit", lambda values: (values > 0).sum()),
            Total_Profit=("Profit", "sum"),
            Average_RR=("RR", "mean"),
            Expectancy=("Profit", "mean"),
        )
        .reset_index()
    )
    grouped["Win Rate"] = grouped["Wins"] / grouped["Trades"] * 100
    grouped = grouped.rename(columns={"Total_Profit": "Total Profit", "Average_RR": "Average RR"})
    return grouped.drop(columns=["Wins"]).sort_values("Total Profit", ascending=False)


def day_of_week_analysis(trades: pd.DataFrame) -> pd.DataFrame:
    if trades.empty:
        return pd.DataFrame(columns=["Day", "Trades", "Profit", "Win Rate"])

    data = trades.copy()
    data["Date"] = pd.to_datetime(data["Date"], errors="coerce")
    data = data.dropna(subset=["Date"])
    if data.empty:
        return pd.DataFrame(columns=["Day", "Trades", "Profit", "Win Rate"])

    data["Day"] = data["Date"].dt.day_name()
    result = (
        data.groupby("Day")
        .agg(Trades=("Day", "size"), Profit=("Profit", "sum"), Wins=("Profit", lambda values: (values > 0).sum()))
        .reset_index()
    )
    result["Win Rate"] = result["Wins"] / result["Trades"] * 100
    days = ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"]
    result["Day"] = pd.Categorical(result["Day"], categories=days, ordered=True)
    return result.drop(columns=["Wins"]).sort_values("Day")


def compliance_comparison(trades: pd.DataFrame) -> pd.DataFrame:
