        </div>
        """,
        unsafe_allow_html=True,
    )


def render_goal_progress(title: str, current: float, target: float, detail: str) -> None:
    progress = clamp_progress(current, target)
    st.markdown(
        f"""
        <div class="goal-card">
            <div class="goal-title">{title}</div>
            <div class="goal-meta">{detail}</div>
        </div>
        """,
        unsafe_allow_html=True,
    )
    st.progress(progress, text=f"{percent(progress * 100)} complete")


def safe_filename(value: str) -> str:
    cleaned = re.sub(r"[^A-Za-z0-9_.-]+", "_", value.strip())
    return cleaned.strip("._") or "image"


def default_value_for_column(column: str) -> object:
    if column == "Grade":
        return "C"
    if column == "Trade Session":
        return "Morning"
    if column == "Emotional State":
        return "Neutral"
    if column == "Compliance Score":
        return 100
    if column == "Trade Quality Score":
        return 0
    if column in MISTAKE_COLUMNS:
        return False
    if column in [
        "Date",
        "Ticker",
        "Direction",
        "Setup",
        "Notes",
        "Account",
        "Type",
        "Followed Plan",
        "Take Again",
        "Pre-Trade Notes",
        "Post-Trade Review",
        "What Worked",
        "What Failed",
        "Setup Name",
        "Description",
        "Entry Rules",
        "Exit Rules",
        "Risk Rules",
        "Screenshot",
        *IMAGE_COLUMNS,
    ]:
        return ""
    return 0


def ensure_csv(path: Path, columns: list[str], seed_rows: list[dict[str, object]] | None = None) -> None:
    if not path.exists():
        pd.DataFrame(seed_rows or [], columns=columns).to_csv(path, index=False)
        return

    df = pd.read_csv(path)
    missing_columns = [column for column in columns if column not in df.columns]
    if not missing_columns:
        return

    for column in missing_columns:
        df[column] = default_value_for_column(column)
    df[columns].to_csv(path, index=False)


