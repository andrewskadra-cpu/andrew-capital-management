    top = leaderboard.iloc[0]

    st.subheader("Executive KPI Cards")
    kpi1, kpi2, kpi3, kpi4 = st.columns(4)
    with kpi1:
        render_kpi_card("Highest Ranked Opportunity", str(top["Opportunity"]), f"Score {top['Score']:.1f}/100")
    with kpi2:
        render_kpi_card("Expected Return", percent(float(top["Expected ROI"])), "Projected annualized ROI")
    with kpi3:
        render_kpi_card("Risk Rating", str(top["Risk Level"]), f"Tolerance: {risk_tolerance}")
    with kpi4:
        render_kpi_card("Capital Available", money(available_capital), f"Horizon: {investment_horizon}")

    st.subheader("Best Use of Capital Recommendation")
    st.success(
        f"{top['Opportunity']} ranks highest due to its projected return, risk fit, liquidity fit, scalability, and passive income potential."
    )

    st.subheader("Opportunity Leaderboard")
    display = leaderboard[["Opportunity", "Score", "Expected ROI", "Risk Level", "Liquidity", "Recommendation"]].copy()
    display["Expected ROI"] = display["Expected ROI"].map(percent)
    st.dataframe(display, use_container_width=True, hide_index=True)

    chart_col1, chart_col2 = st.columns(2)
    with chart_col1:
        st.subheader("Opportunity Scores")
        if px is not None:
            fig = px.bar(
                leaderboard,
                x="Opportunity",
                y="Score",
                color="Recommendation",
                range_y=[0, 100],
                template="plotly_dark",
            )
            st.plotly_chart(fig, use_container_width=True)
        else:
            st.bar_chart(leaderboard.set_index("Opportunity")["Score"])

    with chart_col2:
        st.subheader("ROI vs Risk")
        if px is not None:
            risk_numeric = leaderboard["Risk Level"].map({"Low": 25, "Medium": 55, "High": 85})
            scatter_data = leaderboard.assign(Risk=risk_numeric)
            fig = px.scatter(
                scatter_data,
                x="Risk",
                y="Expected ROI",
                size="Score",
                color="Opportunity",
                hover_name="Opportunity",
                template="plotly_dark",
            )
            st.plotly_chart(fig, use_container_width=True)
        else:
            st.scatter_chart(leaderboard, x="Score", y="Expected ROI")


def render_sidebar() -> str:
    st.sidebar.title(APP_NAME)
    return st.sidebar.selectbox(
        "Navigation",
        ["Dashboard", "Trading", "Wealth", "Real Estate", "Acquisitions", "Executive Decision Engine"],
    )


def main() -> None:
    configure_page()
    initialize_files()
    page = render_sidebar()

    if page == "Dashboard":
        render_dashboard()
    elif page == "Trading":
        render_trading_center()
    elif page == "Wealth":
        render_wealth_dashboard()
    elif page == "Real Estate":
        render_real_estate_analyzer()
    elif page == "Acquisitions":
        render_acquisition_analyzer()
    elif page == "Executive Decision Engine":
        render_executive_decision_engine()


if __name__ == "__main__":
    main()
