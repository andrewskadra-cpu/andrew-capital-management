def money(value: float) -> str:
    return f"${value:,.2f}"


def percent(value: float) -> str:
    return f"{value:.1f}%"


def safe_filename(value: str) -> str:
    cleaned = re.sub(r"[^A-Za-z0-9_.-]+", "_", value.strip())
    return cleaned.strip("._") or "image"


def default_value_for_column(column: str) -> object:
    if column == "Grade":
        return "C"
    if column in MISTAKE_COLUMNS:
        return False
    if column in ["Date", "Ticker", "Direction", "Setup", "Notes", "Account", "Type", *IMAGE_COLUMNS]:
        return ""
    return 0


def ensure_csv(path: Path, columns: list[str], seed_rows: list[dict[str, object]] | None = None) -> None:
    if not path.exists():
        pd.DataFrame(seed_rows or [], columns=columns).to_csv(path, index=False)
        return

    df = pd.read_csv(path)
    missing_columns = [column for column in columns if column not in df.columns]
    if not missing_columns:
        return

    for column in missing_columns:
        df[column] = default_value_for_column(column)
    df[columns].to_csv(path, index=False)


