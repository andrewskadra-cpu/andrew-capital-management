def read_trades() -> pd.DataFrame:
    df = pd.read_csv(TRADES_FILE)
    for column in TRADE_COLUMNS:
        if column not in df.columns:
            df[column] = default_value_for_column(column)

    df = df[TRADE_COLUMNS].copy()
    df["Date"] = pd.to_datetime(df["Date"], errors="coerce").dt.date
    df["Ticker"] = df["Ticker"].fillna("").astype(str).str.upper().str.strip()
    df["Direction"] = df["Direction"].fillna("Long").astype(str)
    df["Setup"] = df["Setup"].fillna("Other").astype(str)
    df["Grade"] = df["Grade"].fillna("C").astype(str).str.upper().str.strip()
    df.loc[~df["Grade"].isin(TRADE_GRADES), "Grade"] = "C"
    df["Notes"] = df["Notes"].fillna("").astype(str)
    for column in MISTAKE_COLUMNS:
        df[column] = df[column].map(parse_checkbox_value).fillna(False).astype(bool)
    for column in IMAGE_COLUMNS:
        df[column] = df[column].fillna("").astype(str)

    for column in ["Entry", "Stop", "Target", "Exit", "Shares", "Profit", "RR"]:
        df[column] = pd.to_numeric(df[column], errors="coerce").fillna(0.0)

    df["Result"] = df["Profit"].apply(lambda value: "Win" if value > 0 else "Loss" if value < 0 else "Flat")
    return df


def save_trades(df: pd.DataFrame) -> None:
    df[TRADE_COLUMNS].to_csv(TRADES_FILE, index=False)


def save_uploaded_image(uploaded_file: object, ticker: str, label: str) -> str:
    if uploaded_file is None:
        return ""

    TRADE_IMAGES_DIR.mkdir(parents=True, exist_ok=True)
    original_name = safe_filename(uploaded_file.name)
    suffix = Path(original_name).suffix.lower()
    if suffix not in [".png", ".jpg", ".jpeg", ".webp"]:
        suffix = ".png"

    timestamp = pd.Timestamp.now().strftime("%Y%m%d_%H%M%S_%f")
    clean_ticker = safe_filename(ticker.upper() or "TRADE")
    clean_label = safe_filename(label)
    file_name = f"{timestamp}_{clean_ticker}_{clean_label}{suffix}"
    destination = TRADE_IMAGES_DIR / file_name
    destination.write_bytes(uploaded_file.getbuffer())
    return str(Path("trade_images") / file_name)


def resolve_image_path(path_value: object) -> Path | None:
    if pd.isna(path_value):
        return None
    path_text = str(path_value).strip()
    if not path_text:
        return None

    candidate = Path(path_text)
    if not candidate.is_absolute():
        candidate = APP_DIR / candidate
    return candidate


def parse_checkbox_value(value: object) -> bool:
    if isinstance(value, bool):
        return value
    if pd.isna(value):
        return False
    if isinstance(value, (int, float)):
        return value != 0
    return str(value).strip().lower() in {"true", "1", "yes", "y", "checked"}


