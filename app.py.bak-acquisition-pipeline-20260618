        st.info("No mistakes have been marked for the selected trades.")
        return

    most_common = analysis.iloc[0]
    col1, col2, col3 = st.columns(3)
    col1.metric("Most Common Mistake", str(most_common["Mistake"]))
    col2.metric("Mistake Count", f"{int(most_common['Count']):,}")
